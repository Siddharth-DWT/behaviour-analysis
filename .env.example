# ============================================================================
# NEXUS Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================================

# --- Python Path (required for shared/* imports) ---
# Set this to the project root so all services can import shared.*
# On Windows use the full path: PYTHONPATH=C:\Users\ADMIN\Desktop\behaviour-analysis
PYTHONPATH=.

# --- Database ---
POSTGRES_PASSWORD=nexus_dev_2026
DATABASE_URL=postgresql://nexus:nexus_dev_2026@localhost:5432/nexus

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Provider ---
# Which LLM to use for intent classification + narrative reports
# Options: "openai" (default, uses gpt-4o-mini) or "anthropic" (uses claude-sonnet-4-20250514)
LLM_PROVIDER=openai

# --- API Keys ---
# At least one key is required depending on LLM_PROVIDER
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Optional: Override the default model for the chosen provider
# LLM_MODEL=gpt-4o-mini

# --- External GPU APIs (optional — accelerates transcription, TTS & diarization) ---
# Remote server with NVIDIA RTX 5090 running Whisper STT + Coqui TTS + pyannote
# When set, Voice Agent uses GPU APIs instead of local CPU processing
# EXTERNAL_WHISPER_URL=http://110.227.200.12:8008
# EXTERNAL_TTS_URL=http://110.227.200.12:8009
# EXTERNAL_DIARIZE_URL=http://110.227.200.12:8008   # GPU pyannote diarization (can share server with Whisper)
# EXTERNAL_API_KEY=your-api-key-here
# EXTERNAL_WHISPER_MODEL=base   # tiny/base/small/medium/large-v2/large-v3

# --- Authentication ---
# JWT secret for signing access tokens (auto-generated if not set, but will change on restart)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-64-char-hex-string-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Email (ZeptoMail / Zoho transactional email) ---
# ZEPTOMAIL_TOKEN=Zoho-enczapikey***
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=NEXUS
# APP_URL=http://localhost:3000

# --- Optional (not needed for vertical slice) ---
# RECALL_AI_KEY=your_recall_ai_key
# DEEPGRAM_API_KEY=your_deepgram_api_key
