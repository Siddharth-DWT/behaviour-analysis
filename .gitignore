# ── Model files (downloaded/generated at runtime, never commit) ──────────────
# Root-level legacy model dirs
/models/
pretrained_models/

# Backend model dirs
backend/models/mediapipe/
backend/models/distilbert-onnx/
backend/models/distilbert-onnx-int8/

# Model file extensions
*.pt
*.bin
*.onnx
*.tflite
*.task

# ── Data directories (runtime files, large binaries) ─────────────────────────
# Root-level data (legacy layout)
data/recordings/*
data/reports/*
data/overlays/
!data/recordings/.gitkeep
!data/reports/.gitkeep

# Backend data (monolith layout)
backend/data/recordings/*
backend/data/overlays/
backend/data/reports/*.json
backend/data/reports/*.jsonl
!backend/data/recordings/.gitkeep
!backend/data/reports/.gitkeep
!backend/data/labels/.gitkeep

# ── Docker volumes ────────────────────────────────────────────────────────────
postgres_data/
redis_data/

# ── Log files ─────────────────────────────────────────────────────────────────
.logs/
.pids/
*.log
server_logs.txt
task_log.txt

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Stale hyphenated service dirs (code lives in voiceAgent/, api_gateway/) ──
services/voice-agent/
services/language-agent/
services/fusion-agent/
services/api-gateway/
recordings/